import gradio as gr          # 웹 UI를 만들어주는 라이브러리
import numpy as np           # 숫자 배열(행렬) 계산 라이브러리 (이미지는 숫자 배열로 표현됨)
from PIL import Image, ImageFilter  # 이미지 처리 라이브러리
import matplotlib.colors as mcolors # 색상 변환 라이브러리 (RGB ↔ HSV 변환)

# =============================================
# [자료구조: 딕셔너리 (Dictionary)]
#
# 딕셔너리란?
# - "키(key): 값(value)" 쌍으로 데이터를 저장하는 자료구조
# - 리스트는 번호(인덱스)로 접근하지만, 딕셔너리는 이름(키)으로 접근
# - 예: 영어사전처럼 단어(키)로 뜻(값)을 찾는 것
#
# 여기서 사용법:
# - 키 = 프리셋 이름 (문자열)
# - 값 = 필터 설정값 묶음 (튜플: 밝기, 채도, 블러, 엣지)
#
# 접근 방법:
# presets["따뜻한 느낌"] → (1.2, 1.5, 0, False) 반환
# =============================================
presets = {
    # "프리셋 이름": (밝기, 채도, 블러강도, 엣지감지)
    "기본값":      (1.0, 1.0, 0, False),  # 모든 값이 기본 → 원본과 동일
    "따뜻한 느낌": (1.2, 1.5, 0, False),  # 밝기↑ 채도↑ → 따뜻하고 화사한 느낌
    "흑백 스케치": (1.0, 0.0, 0, True),   # 채도=0(흑백) + 엣지감지=True → 스케치 효과
    "몽환적":      (0.8, 1.3, 5, False),  # 밝기↓ 블러↑ → 흐릿하고 몽환적인 느낌
    "선명하게":    (1.3, 1.8, 0, False),  # 밝기↑ 채도↑↑ → 선명하고 강렬한 느낌
    "빈티지":      (0.9, 0.6, 1, False),  # 어둡고 채도↓ → 오래된 사진 느낌
}


def process_image(image, brightness, saturation, blur_radius, show_edge):
    """
    이미지에 기본 필터들을 순서대로 적용하는 함수

    [매개변수 설명]
    - image       : 업로드한 원본 이미지 (PIL Image 형식)
    - brightness  : 밝기 배율 (1.0=원본, 2.0=2배 밝게, 0.5=절반 어둡게)
    - saturation  : 채도 배율 (1.0=원본, 0.0=흑백, 2.0=2배 선명하게)
    - blur_radius : 블러 반지름 (0=블러없음, 숫자 클수록 더 흐릿하게)
    - show_edge   : 엣지 감지 여부 (True=윤곽선만 표시, False=일반 이미지)

    [반환값]
    - 필터가 적용된 PIL Image
    """

    # 이미지가 없으면 None 반환 (오류 방지용)
    if image is None:
        return None

    # PIL Image를 NumPy 배열로 변환
    # 이미지는 픽셀값(0~255)의 3차원 배열: [세로][가로][RGB채널]
    # 예: 100x100 이미지 → shape (100, 100, 3) 배열
    img_array = np.array(image)

    # -----------------------------------------------
    # [1단계: 밝기 조절]
    # 모든 픽셀값에 brightness 배율을 곱함
    # 픽셀값 * 1.5 → 1.5배 밝아짐
    # np.clip: 결과값이 0~255 범위를 벗어나지 않도록 자름
    #   예: 200 * 1.5 = 300 → np.clip → 255로 제한
    # .astype(np.uint8): 정수형으로 변환 (픽셀값은 정수여야 함)
    # -----------------------------------------------
    img_array = np.clip(img_array * brightness, 0, 255).astype(np.uint8)

    # -----------------------------------------------
    # [2단계: 채도 조절]
    # RGB 색상 공간에서는 채도만 조절하기 어려움
    # → HSV 색상 공간으로 변환 후 채도(S)만 조절
    #
    # HSV란?
    # H (Hue, 색조)     : 색의 종류 (빨강, 노랑, 초록... 0~360도)
    # S (Saturation, 채도): 색의 선명함 (0=흑백, 1=최대 선명)
    # V (Value, 명도)    : 색의 밝기 (0=검정, 1=최대 밝음)
    # -----------------------------------------------

    # 픽셀값을 0~255에서 0~1 범위로 정규화 (HSV 변환에 필요)
    img_float = img_array / 255.0

    # RGB → HSV 색상 공간으로 변환
    img_hsv = mcolors.rgb_to_hsv(img_float)

    # HSV 배열에서 채도(S)만 꺼내서 saturation 배율 곱함
    # [:, :, 1] → 모든 행, 모든 열, 1번 채널(S=채도)
    # np.clip: 채도값이 0~1 범위를 벗어나지 않도록 제한
    img_hsv[:, :, 1] = np.clip(img_hsv[:, :, 1] * saturation, 0, 1)

    # HSV → RGB로 다시 변환 후 0~255 범위로 되돌림
    img_array = (mcolors.hsv_to_rgb(img_hsv) * 255).astype(np.uint8)

    # -----------------------------------------------
    # [3단계: 블러 처리]
    # GaussianBlur: 가우시안 분포를 이용해 주변 픽셀을 평균냄
    # blur_radius가 클수록 더 넓은 범위를 평균 → 더 흐릿해짐
    # blur_radius = 0이면 블러 적용 안 함
    # -----------------------------------------------

    # NumPy 배열 → PIL Image로 변환 (PIL 필터 사용을 위해)
    img_pil = Image.fromarray(img_array)

    if blur_radius > 0:  # 블러 강도가 0보다 클 때만 적용
        img_pil = img_pil.filter(ImageFilter.GaussianBlur(radius=blur_radius))

    # -----------------------------------------------
    # [4단계: 엣지 감지]
    # FIND_EDGES: 픽셀값이 급격히 변하는 경계선(엣지)을 찾음
    # 인접한 픽셀들의 차이가 클수록 밝게 표시됨
    # show_edge = True일 때만 적용
    # -----------------------------------------------
    if show_edge:
        img_pil = img_pil.filter(ImageFilter.FIND_EDGES)

    return img_pil  # 최종 처리된 이미지 반환


def color_splash(image, target_color, threshold):
    """
    Color Splash 효과를 적용하는 함수
    선택한 색상과 비슷한 픽셀만 컬러로 남기고, 나머지는 흑백으로 변환

    [동작 원리]
    1. 전체 이미지를 흑백으로 변환
    2. 각 픽셀과 선택한 색상의 차이를 계산
    3. 차이가 threshold보다 작은 픽셀 → 원본 컬러 유지
    4. 차이가 threshold보다 큰 픽셀 → 흑백으로 변환

    [매개변수 설명]
    - image        : 원본 이미지 (PIL Image 형식)
    - target_color : 남길 색상 (hex 코드 문자열, 예: "#FF0000" = 빨강)
    - threshold    : 색상 허용 범위 (0~255, 높을수록 비슷한 색도 컬러로 남김)

    [반환값]
    - Color Splash가 적용된 PIL Image
    """

    # 이미지가 없으면 None 반환
    if image is None:
        return None

    # -----------------------------------------------
    # [hex 색상코드 → RGB 숫자로 변환]
    # hex 코드란? 색상을 16진수로 표현한 것
    # 예: "#FF0000" → 빨강 (R=255, G=0, B=0)
    #     "#00FF00" → 초록 (R=0, G=255, B=0)
    #     "#0000FF" → 파랑 (R=0, G=0, B=255)
    #
    # .lstrip('#') : 맨 앞의 '#' 문자 제거
    # int(..., 16) : 16진수 문자열을 10진수 정수로 변환
    # for i in (0, 2, 4): 문자열을 2자리씩 잘라서 변환
    #   "#FF0000" → "FF"=255, "00"=0, "00"=0
    # -----------------------------------------------
    target_color = target_color.lstrip('#')
    target_rgb = tuple(int(target_color[i:i+2], 16) for i in (0, 2, 4))
    # 결과: target_rgb = (255, 0, 0) ← 빨강인 경우

    # 이미지를 NumPy 배열로 변환 (float32: 소수점 계산을 위해)
    img_array = np.array(image).astype(np.float32)

    # -----------------------------------------------
    # [흑백 이미지 생성]
    # 단순히 RGB 평균을 내는 것보다
    # 사람 눈의 민감도를 반영한 가중치를 사용
    # R(빨강): 0.299 → 사람 눈이 가장 덜 민감
    # G(초록): 0.587 → 사람 눈이 가장 민감 (가중치 가장 높음)
    # B(파랑): 0.114 → 중간 민감도
    # 이 공식은 ITU-R BT.601 표준 (TV/영상 분야에서 사용)
    # -----------------------------------------------
    gray = (0.299 * img_array[:,:,0] +   # R 채널 * 가중치
            0.587 * img_array[:,:,1] +   # G 채널 * 가중치
            0.114 * img_array[:,:,2])    # B 채널 * 가중치

    # -----------------------------------------------
    # [각 픽셀과 선택한 색상의 차이 계산]
    # np.abs(): 절댓값 (차이는 항상 양수)
    # 예: 픽셀 R값=200, 선택색 R값=255
    #     diff_r = |200 - 255| = 55
    # -----------------------------------------------
    diff_r = np.abs(img_array[:,:,0] - target_rgb[0])  # R채널 차이
    diff_g = np.abs(img_array[:,:,1] - target_rgb[1])  # G채널 차이
    diff_b = np.abs(img_array[:,:,2] - target_rgb[2])  # B채널 차이

    # R, G, B 차이의 평균 → 전체적인 색상 차이
    color_diff = (diff_r + diff_g + diff_b) / 3

    # -----------------------------------------------
    # [색상 마스크 생성]
    # color_diff < threshold : 차이가 허용 범위 안에 있는 픽셀
    # → True : 선택한 색상과 비슷함 → 컬러 유지
    # → False: 선택한 색상과 다름 → 흑백으로 변환
    # -----------------------------------------------
    color_mask = color_diff < threshold
    # color_mask는 True/False로 이뤄진 2D 배열
    # True인 위치 = 컬러 유지할 픽셀
    # False인 위치 = 흑백으로 바꿀 픽셀

    # -----------------------------------------------
    # [결과 이미지 생성]
    # np.zeros_like(): 원본과 같은 크기의 0으로 채워진 배열 생성
    # -----------------------------------------------
    result = np.zeros_like(img_array)

    # 마스크가 True인 픽셀 → 원본 컬러 값 복사
    result[color_mask] = img_array[color_mask]

    # 마스크가 False인 픽셀 → 흑백값으로 채움
    # ~color_mask : 마스크를 반전 (True↔False)
    # 3개 채널(R,G,B) 모두 같은 gray값으로 설정 → 흑백
    for channel in range(3):  # 0=R, 1=G, 2=B 채널 반복
        result[:,:,channel][~color_mask] = gray[~color_mask]

    # NumPy 배열 → PIL Image로 변환 후 반환
    return Image.fromarray(result.astype(np.uint8))


def apply_preset(preset_name):
    """
    프리셋 이름을 받아서 해당 설정값을 반환하는 함수

    [동작 방식]
    딕셔너리에서 키(프리셋 이름)로 값(설정값 튜플)을 조회
    반환된 값이 각 슬라이더/체크박스에 자동으로 적용됨

    [매개변수]
    - preset_name: 선택한 프리셋 이름 (딕셔너리의 키)

    [반환값]
    - 밝기, 채도, 블러, 엣지감지 값 (4개)
    """

    # 딕셔너리에서 프리셋 이름으로 설정값 가져오기
    values = presets[preset_name]

    # 튜플을 분리해서 개별 값으로 반환
    # Gradio는 여러 값을 반환하면 각 출력 컴포넌트에 순서대로 적용
    return values[0], values[1], values[2], values[3]


# =============================================
# [Gradio UI 구성]
#
# gr.Blocks() : UI 요소를 자유롭게 배치할 수 있는 컨테이너
# gr.Tabs()   : 탭으로 화면 분리 (기본필터 / Color Splash)
# gr.Row()    : 요소를 가로로 나란히 배치
# gr.Column() : 요소를 세로로 쌓아서 배치
# =============================================
with gr.Blocks(title="필터 툴") as demo:

    gr.Markdown("# 🎨 이미지 필터 툴")
    gr.Markdown("이미지를 업로드하고 필터를 조절해보세요!")

    # 탭으로 두 가지 기능 분리
    with gr.Tabs():

        # -----------------------------------------------
        # [탭 1: 기본 필터]
        # 밝기, 채도, 블러, 엣지감지 + 프리셋 기능
        # -----------------------------------------------
        with gr.Tab("🎛️ 기본 필터"):
            with gr.Row():

                # 왼쪽: 입력 영역
                with gr.Column():
                    input_image1 = gr.Image(type="pil", label="이미지 업로드")

                    # 프리셋 드롭다운
                    # list(presets.keys()) : 딕셔너리의 키(이름)들을 리스트로 변환
                    # → ["기본값", "따뜻한 느낌", "흑백 스케치", ...]
                    preset_dropdown = gr.Dropdown(
                        choices=list(presets.keys()),  # 선택지 = 딕셔너리 키 목록
                        value="기본값",               # 초기 선택값
                        label="🎭 프리셋 선택 (선택 시 슬라이더 자동 변경)"
                    )

                    # 각 필터 슬라이더 (수동으로도 조절 가능)
                    brightness_slider = gr.Slider(
                        minimum=0.1, maximum=3.0,
                        value=1.0, label="☀️ 밝기 (1.0=원본)"
                    )
                    saturation_slider = gr.Slider(
                        minimum=0.0, maximum=3.0,
                        value=1.0, label="🎨 채도 (0=흑백, 1.0=원본)"
                    )
                    blur_slider = gr.Slider(
                        minimum=0, maximum=10,
                        value=0, label="💨 블러 강도 (0=없음)"
                    )
                    edge_checkbox = gr.Checkbox(label="✏️ 엣지 감지")

                    apply_btn1 = gr.Button("✅ 필터 적용", variant="primary")

                # 오른쪽: 결과 이미지
                with gr.Column():
                    output_image1 = gr.Image(label="결과 이미지")

            # -----------------------------------------------
            # [이벤트 연결 1: 프리셋 선택 시 슬라이더 자동 변경]
            # .change() : 드롭다운 값이 바뀔 때 실행
            # inputs  : apply_preset 함수에 전달할 값
            # outputs : apply_preset 함수가 반환한 값을 적용할 컴포넌트
            # -----------------------------------------------
            preset_dropdown.change(
                fn=apply_preset,
                inputs=[preset_dropdown],
                outputs=[brightness_slider, saturation_slider,
                         blur_slider, edge_checkbox]
            )

            # -----------------------------------------------
            # [이벤트 연결 2: 필터 적용 버튼 클릭]
            # .click() : 버튼 클릭 시 실행
            # -----------------------------------------------
            apply_btn1.click(
                fn=process_image,
                inputs=[input_image1, brightness_slider,
                        saturation_slider, blur_slider, edge_checkbox],
                outputs=[output_image1]
            )

        # -----------------------------------------------
        # [탭 2: Color Splash]
        # 선택한 색상만 컬러로 남기고 나머지 흑백
        # -----------------------------------------------
        with gr.Tab("✨ Color Splash"):
            gr.Markdown("### 원하는 색상만 살리고 나머지는 흑백으로!")
            gr.Markdown("💡 팁: 감지 범위를 낮추면 정확한 색만, 높이면 비슷한 색도 포함됩니다")

            with gr.Row():

                # 왼쪽: 입력 영역
                with gr.Column():
                    input_image2 = gr.Image(type="pil", label="이미지 업로드")

                    # 컬러 피커: 마우스로 색상 선택
                    # value="#FF0000" : 초기값 빨강
                    color_picker = gr.ColorPicker(
                        value="#FF0000",
                        label="🎨 남길 색상 선택 (클릭해서 색 고르기)"
                    )

                    # 색상 감지 범위 슬라이더
                    # 낮음(10) : 완전히 같은 색만 → 효과 강하게
                    # 높음(150): 비슷한 색도 포함 → 효과 부드럽게
                    threshold_slider = gr.Slider(
                        minimum=10, maximum=150,
                        value=60, step=5,
                        label="🎯 색상 감지 범위 (낮을수록 정확, 높을수록 넓게)"
                    )

                    splash_btn = gr.Button("✨ Color Splash 적용", variant="primary")

                # 오른쪽: 결과 이미지
                with gr.Column():
                    output_image2 = gr.Image(label="결과 이미지")

            # [이벤트 연결: Color Splash 버튼 클릭]
            splash_btn.click(
                fn=color_splash,
                inputs=[input_image2, color_picker, threshold_slider],
                outputs=[output_image2]
            )

demo.launch()
